# ==========================================
# WatchSync 專案環境變數設定檔 (範例)
# 部署時，請將此檔複製並重新命名為 .env，然後填入真實的數值
# ==========================================

# 1. Discord 機器人認證
DISCORD_TOKEN=your_discord_bot_token_here

# 2. 機器人發送通知的指定文字頻道 ID
CHANNEL_ID=your_discord_channel_id_here

# 3. 監控目標帳號 (請勿加 @，如果有多個帳號請用逗號分隔)
IG_ACCOUNTS=daily_patelle
THREADS_ACCOUNTS=daily_patelle
